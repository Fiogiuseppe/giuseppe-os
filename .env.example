# Server override — mock forces local intelligence (CI/tests). Live calls require dev toggle or AI_ALLOW_CLIENT_LIVE.
AI_MODE=mock

# Never set on a public/shared deploy unless you accept visitor-triggered API costs.
# AI_ALLOW_CLIENT_LIVE=true

# Brain API provider (claude | openai | gemini | local | rule-based)
BRAIN_AI_PROVIDER=claude

# Claude (only when footer AI is ON and this key is set)
ANTHROPIC_API_KEY=
BRAIN_AI_MODEL=claude-sonnet-4-6

# OpenAI (future)
OPENAI_API_KEY=
BRAIN_OPENAI_MODEL=gpt-4.1

# Gemini (future)
GEMINI_API_KEY=
BRAIN_GEMINI_MODEL=gemini-2.0-flash

# Local models (future)
LOCAL_AI_ENDPOINT=
BRAIN_LOCAL_MODEL=local-model

# Persistent memory (json | supabase). Supabase requires schema in supabase/schema.sql.
MEMORY_BACKEND=json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
