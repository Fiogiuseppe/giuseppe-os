# AI cost control — mock (default in development) | live
AI_MODE=mock

# Brain API provider (claude | openai | gemini | local | rule-based)
BRAIN_AI_PROVIDER=claude

# Claude (only used when AI_MODE=live)
ANTHROPIC_API_KEY=
BRAIN_AI_MODEL=claude-sonnet-4-6

# OpenAI (future)
OPENAI_API_KEY=
BRAIN_OPENAI_MODEL=gpt-4.1

# Gemini (future)
GEMINI_API_KEY=
BRAIN_GEMINI_MODEL=gemini-2.0-flash

# Local models (future)
LOCAL_AI_ENDPOINT=
BRAIN_LOCAL_MODEL=local-model

# Persistent memory (json | supabase). Supabase requires schema in supabase/schema.sql.
MEMORY_BACKEND=json
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
