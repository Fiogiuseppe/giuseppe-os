# AI activates automatically when a provider key is present.
# Set AI_MODE=mock only to force offline/test behaviour.

# Brain API provider (gemini | requesty | openai | local | rule-based)
BRAIN_AI_PROVIDER=gemini

# Gemini — any one of these names works on Vercel
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional Gemini model override (default: gemini-2.0-flash)
# BRAIN_GEMINI_MODEL=gemini-2.0-flash

# Requesty — optional paid alternative
# REQUESTY_API_KEY=
# BRAIN_AI_MODEL=openai/gpt-5-mini

# Local Ollama chat fallback (development only, when no cloud key is set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
