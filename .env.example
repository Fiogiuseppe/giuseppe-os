# Server-only AI control — mock (default) | live (requires REQUESTY_API_KEY on server)
AI_MODE=mock

# Brain API provider (requesty | openai | gemini | local | rule-based)
BRAIN_AI_PROVIDER=requesty

# Requesty — required for online AI (Brain, Daily Briefing, /api/chat on Vercel)
REQUESTY_API_KEY=

# Optional model override (default: openai/gpt-5-mini)
# BRAIN_AI_MODEL=openai/gpt-5-mini

# Local Ollama chat fallback (development only, when REQUESTY_API_KEY is unset)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
