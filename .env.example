AI_MODE=live

# Canonical provider selector — change only this to switch providers
AI_PROVIDER=groq

# Deprecated alias (still read if AI_PROVIDER is unset)
# BRAIN_AI_PROVIDER=groq

# Groq — primary online provider (free tier, no card required)
GROQ_API_KEY=

# Optional Groq model override (default: llama-3.3-70b-versatile)
# BRAIN_GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallbacks
# GEMINI_API_KEY=
# REQUESTY_API_KEY=

# Local Ollama chat fallback (development only, when no cloud key is set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# UREES website connector — defaults to official https://urees.shop/
# UREES_WEBSITE_URL=https://urees.shop/
# UREES_WEBSITE_FEED_URL=
# UREES_WEBSITE_SITEMAP_URL=
# UREES_WEBSITE_PRODUCTS_URL=
# UREES_WEBSITE_MAX_PAGES=12

# Sources OAuth — server-side only (never expose client_secret to the browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
